{
  // Misc Settings
  "breadcrumbs.enabled": true,
  "explorer.confirmDragAndDrop": true,
  "explorer.compactFolders": false,
  "security.workspace.trust.enabled": true,
  "security.workspace.trust.untrustedFiles": "open",
  "search.useGlobalIgnoreFiles": true,
  "symbols.hidesExplorerArrows": false,
  // Workbench Settings
  "workbench.colorTheme": "Vesper",
  "workbench.iconTheme": "symbols",
  "workbench.sideBar.location": "right",
  "workbench.activityBar.compact": true,
  // Git Settings
  "git.confirmSync": false,
  "git.autofetch": true,
  // Terminal Settings
  "terminal.integrated.cursorStyle": "line",
  "terminal.external.osxExec": "Ghostty.app",
  "terminal.explorerKind": "external",
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font', monospace",
  "terminal.integrated.defaultProfile.osx": "zsh",
  // Editor Settings
  "editor.cursorBlinking": "solid",
  "editor.detectIndentation": true,
  "editor.fontSize": 14,
  "editor.lineHeight": 0,
  "editor.minimap.enabled": false,
  "editor.formatOnSave": true,
  "editor.fontFamily": "'Monaspace Neon', monospace",
  "editor.inlineSuggest.fontFamily": "'Monaspace Krypton', monospace",
  "editor.fontLigatures": "'calt', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08', 'ss09', 'ss10', 'liga'",
  "editor.linkedEditing": true,
  // Github Copilot Settings
  "chat.tools.terminal.enableAutoApprove": true,
  "chat.agent.maxRequests": 100,
  "chat.editor.fontSize": 12,
  "chat.editing.confirmEditRequestRemoval": false,
  "chat.viewSessions.orientation": "stacked",
  "github.copilot.renameSuggestions.triggerAutomatically": true,
  "github.copilot.editor.enableCodeActions": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Use conventional commit message format."
    },
    {
      "text": "Keep the commit message short and concise. Use imperative mood and avoid unnecessary details."
    }
  ],
  // Claude Code Settings
  "claudeCode.preferredLocation": "sidebar",
  // AI Code Settings
  "gitlens.gitkraken.mcp.autoEnabled": false
}
