#!/usr/bin/env bash
# Source-state hash: {{ include "dot_config/homebrew/Brewfile.tmpl" | sha256sum }}
# Re-runs whenever Brewfile.tmpl content changes.

set -euo pipefail

if ! command -v brew >/dev/null 2>&1; then
  echo "brew not on PATH; skipping brew bundle" >&2
  exit 0
fi

brew bundle --file="$HOME/.config/homebrew/Brewfile"
