#!/bin/bash
# Reinstalls APM dependencies whenever apm.yml or .apm/ content changes.
{{- $src := .chezmoi.sourceDir }}
# apm.yml:       {{ include "dot_config/apm/apm.yml.tmpl" | sha256sum }}
# agents:        {{ range (glob (printf "%s/dot_config/apm/dot_apm/agents/*" $src)) }}{{ include (trimPrefix (printf "%s/" $src) .) | sha256sum }} {{ end }}
# instructions:  {{ range (glob (printf "%s/dot_config/apm/dot_apm/instructions/*" $src)) }}{{ include (trimPrefix (printf "%s/" $src) .) | sha256sum }} {{ end }}
# skills:        {{ range (glob (printf "%s/dot_config/apm/dot_apm/skills/**/*.md" $src)) }}{{ include (trimPrefix (printf "%s/" $src) .) | sha256sum }} {{ end }}

set -e

# APM deploys to <cwd>/.claude/ — its --global flag goes to ~/.apm/ (Copilot/Codex
# only, per https://microsoft.github.io/apm/reference/cli/install/). For Claude
# there is no native global mode, so we symlink <cwd>/.claude → ~/.claude/. APM
# writes through the symlink, landing files directly where Claude Code reads.
# TODO: for work context using --target copilot, set up a parallel .github/ symlink.
echo "[apm] Linking ~/.config/apm/.claude → ~/.claude/ for global deployment..."
mkdir -p "$HOME/.claude"
cd ~/.config/apm
if [ ! -L .claude ] || [ "$(readlink .claude)" != "$HOME/.claude" ]; then
  rm -rf .claude
  ln -s "$HOME/.claude" .claude
fi

echo "[apm] Installing dependencies from apm.yml..."
# MCP servers using ${input:...} interactive prompts (e.g. github-token) fail
# under chezmoi's non-interactive shell. APM integrates agents/skills/rules
# before the MCP step, so a non-zero exit here doesn't lose the deployment.
# Bitwarden integration is the planned long-term fix (roadmap in PROGRESS.md).
apm install --target claude || echo "[apm] apm install exited with errors (likely MCP token prompts in non-interactive shell)"

echo "[apm] Install complete."
