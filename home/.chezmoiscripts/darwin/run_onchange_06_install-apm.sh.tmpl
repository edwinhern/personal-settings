#!/bin/bash
# Reinstalls APM dependencies whenever apm.yml or .apm/ content changes.
{{- $src := .chezmoi.sourceDir }}
# apm.yml:       {{ include "dot_apm/apm.yml.tmpl" | sha256sum }}
# agents:        {{ range (glob (printf "%s/dot_apm/dot_apm/agents/*" $src)) }}{{ include (trimPrefix (printf "%s/" $src) .) | sha256sum }} {{ end }}
# instructions:  {{ range (glob (printf "%s/dot_apm/dot_apm/instructions/*" $src)) }}{{ include (trimPrefix (printf "%s/" $src) .) | sha256sum }} {{ end }}
# skills:        {{ range (glob (printf "%s/dot_apm/dot_apm/skills/**/*.md" $src)) }}{{ include (trimPrefix (printf "%s/" $src) .) | sha256sum }} {{ end }}

set -e

# apm install --global reads apm.yml from ~/.apm/apm.yml (APM's native user-scope
# location) and deploys to ~/.claude/ via CLAUDE_CONFIG_DIR (default ~/.claude/).
# Per the targets matrix: user scope honors CLAUDE_CONFIG_DIR for Claude.
# https://microsoft.github.io/apm/reference/targets-matrix/#claude
echo "[apm] Installing globally from ~/.apm/apm.yml → ~/.claude/..."
cd ~/.apm

# MCP servers using ${input:...} interactive prompts (e.g. github-token) fail
# under chezmoi's non-interactive shell. APM integrates agents/skills/rules
# before the MCP step, so a non-zero exit here doesn't lose the deployment.
# Bitwarden integration is the planned long-term fix (roadmap in PROGRESS.md).
apm install --global --target claude || echo "[apm] apm install exited with errors (likely MCP token prompts in non-interactive shell)"

echo "[apm] Install complete."
