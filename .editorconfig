root = true

[*]
indent_style = space
indent_size = 2
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[Makefile]
indent_style = tab

# shfmt reads .editorconfig natively. shell_variant = bash matches the
# `--shell bash` rule in .shellcheckrc so both tools parse the same dialect.
[*.{sh,zsh,bash}]
shell_variant = bash